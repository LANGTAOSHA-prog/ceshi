<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>极度无聊娱乐公司 | 消磨时间研究所</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            user-select: none; /* 增加一点无聊的选中禁止感，但无伤大雅 */
        }

        body {
            background: linear-gradient(145deg, #2b2b2b 0%, #1f1f2e 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Segoe UI', 'Courier New', 'Fira Code', monospace, system-ui;
            padding: 20px;
            cursor: crosshair;
        }

        /* 主容器 —— 无聊但耀眼的玻璃卡片 */
        .boring-container {
            max-width: 750px;
            width: 100%;
            background: rgba(255, 248, 225, 0.9);
            backdrop-filter: blur(2px);
            border-radius: 72px 48px 84px 48px;
            box-shadow: 0 25px 45px rgba(0,0,0,0.4), inset 0 1px 2px rgba(255,255,200,0.6);
            padding: 28px 24px 38px;
            transition: all 0.2s ease;
            text-align: center;
            border: 2px solid #ffd966;
        }

        /* 标题区 —— 无聊宣言 */
        .unhinged-title {
            font-size: 2.6rem;
            font-weight: 800;
            letter-spacing: -1px;
            background: linear-gradient(135deg, #6b4e2e, #b87c4f, #4e3e2e);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            text-shadow: 4px 4px 12px rgba(0,0,0,0.2);
            margin-bottom: 8px;
        }

        .subbored {
            color: #7a5a4a;
            font-weight: bold;
            font-size: 0.85rem;
            background: #f0e0b0;
            display: inline-block;
            padding: 5px 18px;
            border-radius: 40px;
            letter-spacing: 2px;
            margin-bottom: 25px;
            box-shadow: inset 0 -1px 0 #c0a16b;
        }

        /* 核心无聊计数器 */
        .bored-meter {
            background: #2d2f36;
            border-radius: 100px;
            padding: 15px 20px;
            margin: 20px 0;
            display: flex;
            align-items: baseline;
            justify-content: center;
            gap: 15px;
            flex-wrap: wrap;
            box-shadow: inset 0 2px 6px rgba(0,0,0,0.5), 0 6px 12px rgba(0,0,0,0.2);
        }

        .bored-label {
            font-family: monospace;
            font-weight: bold;
            font-size: 1.6rem;
            color: #ffe3a4;
            letter-spacing: 2px;
        }

        .bored-value {
            font-family: 'Courier New', monospace;
            font-size: 3.8rem;
            font-weight: 800;
            background: #00000077;
            padding: 0 20px;
            border-radius: 60px;
            color: #ffdb7e;
            text-shadow: 0 0 4px rgb(255,200,0);
            min-width: 160px;
            transition: 0.1s linear;
        }

        /* 巨大无聊按钮 */
        .ultra-bored-button {
            background: radial-gradient(circle at 30% 10%, #ffbc6e, #c2591e);
            border: none;
            width: 85%;
            max-width: 320px;
            padding: 24px 12px;
            font-size: 2rem;
            font-weight: bold;
            font-family: monospace;
            color: #2f1f0a;
            text-transform: uppercase;
            border-radius: 999px;
            cursor: pointer;
            box-shadow: 0 18px 0 #7b3a12;
            transition: 0.08s linear;
            margin: 15px auto;
            display: block;
            letter-spacing: 6px;
            transition: all 0.05s linear;
        }

        .ultra-bored-button:active {
            transform: translateY(6px);
            box-shadow: 0 8px 0 #7b3a12;
        }

        /* 随机废料区域 —— 最无聊的惊喜 */
        .random-nonsense {
            background: #faf0cf;
            border-radius: 48px;
            padding: 18px 15px;
            margin: 20px 0 18px;
            border-left: 12px solid #d69b54;
            border-right: 4px solid #e2b87a;
            box-shadow: 0 6px 14px rgba(0,0,0,0.1);
            transition: all 0.2s;
        }

        .nonsense-text {
            font-size: 1.3rem;
            font-weight: 600;
            color: #3b2a1f;
            line-height: 1.4;
            font-family: 'Courier New', monospace;
            word-break: break-word;
        }

        .nonsense-sub {
            font-size: 0.7rem;
            margin-top: 10px;
            color: #ad8b62;
            letter-spacing: 1px;
        }

        /* 无聊小工具组 */
        .silly-tools {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            justify-content: center;
            margin: 25px 0 15px;
        }

        .silly-btn {
            background: #37271b;
            border: none;
            padding: 10px 18px;
            border-radius: 60px;
            font-family: monospace;
            font-weight: bold;
            color: #ffd58c;
            font-size: 0.9rem;
            cursor: pointer;
            transition: 0.1s;
            box-shadow: 0 3px 0 #1a120b;
        }

        .silly-btn:active {
            transform: translateY(2px);
            box-shadow: 0 1px 0 #1a120b;
        }

        /* 会移动的蠢表情 */
        .emoji-wanderer {
            font-size: 3rem;
            display: inline-block;
            transition: transform 0.2s cubic-bezier(0.34, 1.2, 0.8, 1);
            filter: drop-shadow(2px 4px 8px rgba(0,0,0,0.2));
            margin-bottom: 5px;
        }

        .footer-bad-joke {
            font-size: 0.7rem;
            margin-top: 28px;
            color: #7f6b4d;
            border-top: 1px dashed #ccaa77;
            padding-top: 18px;
            display: flex;
            justify-content: center;
            gap: 12px;
        }
        /* 随机抖动效果 */
        @keyframes shakey {
            0% { transform: translate(0px, 0px); }
            25% { transform: translate(2px, -1px);}
            50% { transform: translate(-2px, 2px);}
            75% { transform: translate(1px, -2px);}
            100% { transform: translate(0,0);}
        }
        .shake-soft {
            animation: shakey 0.2s ease-in-out 0s 1;
        }
        @keyframes spinSlow {
            0% { transform: rotate(0deg);}
            100% { transform: rotate(360deg);}
        }
        .spin-emoji {
            animation: spinSlow 0.5s ease-out;
        }
        /* 响应式 */
        @media (max-width: 550px) {
            .bored-value { font-size: 2.5rem; min-width: 100px; }
            .ultra-bored-button { font-size: 1.4rem; letter-spacing: 3px; padding: 18px; }
            .unhinged-title { font-size: 1.9rem; }
            .nonsense-text { font-size: 1rem; }
        }
    </style>
</head>
<body>

