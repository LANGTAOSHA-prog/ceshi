<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>前端在线工具库 | 开发实用工具导航</title>
    <meta name="description" content="精选前端开发工具，每个工具独立链接，开箱即用。包含代码美化、颜色转换、图标速查、JSON处理等日常必备工具。">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(145deg, #f1f4f9 0%, #eef2f5 100%);
            font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', 'Roboto', 'Noto Sans', sans-serif;
            color: #1a2634;
            padding: 2rem 1.5rem;
        }

        /* 主容器 */
        .container {
            max-width: 1400px;
            margin: 0 auto;
        }

        /* header 区域 */
        .hero {
            text-align: center;
            margin-bottom: 3rem;
        }

        .badge {
            display: inline-block;
            background: #ffffffcc;
            backdrop-filter: blur(4px);
            padding: 0.3rem 1rem;
            border-radius: 60px;
            font-size: 0.8rem;
            font-weight: 500;
            color: #2c5f8a;
            border: 1px solid #dce5f0;
            margin-bottom: 1rem;
        }

        h1 {
            font-size: 2.8rem;
            font-weight: 700;
            background: linear-gradient(135deg, #1f3b4c, #2b5f8a);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            letter-spacing: -0.01em;
            margin-bottom: 0.75rem;
        }

        .sub {
            font-size: 1.15rem;
            color: #4a627a;
            max-width: 650px;
            margin: 0 auto;
            border-bottom: 1px solid #cfddee;
            display: inline-block;
            padding-bottom: 0.5rem;
        }

        /* 搜索和筛选栏 (增强实用感) */
        .toolbar {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
            margin: 2rem 0 2rem 0;
            background: #ffffffd9;
            backdrop-filter: blur(8px);
            padding: 0.8rem 1.5rem;
            border-radius: 60px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.02), 0 1px 2px rgba(0, 0, 0, 0.05);
            border: 1px solid #e2ebf3;
        }

        .search-box {
            flex: 2;
            min-width: 200px;
            display: flex;
            align-items: center;
            background: #f8fafd;
            border-radius: 40px;
            padding: 0.3rem 0.8rem;
            border: 1px solid #e2e8f0;
        }

        .search-box span {
            font-size: 1.2rem;
            margin-right: 0.5rem;
            opacity: 0.7;
        }

        .search-box input {
            border: none;
            background: transparent;
            padding: 0.65rem 0.2rem;
            width: 100%;
            font-size: 0.95rem;
            outline: none;
            font-family: inherit;
        }

        .filter-group {
            display: flex;
            gap: 0.6rem;
            flex-wrap: wrap;
        }

        .filter-chip {
            background: #f1f5f9;
            padding: 0.4rem 1rem;
            border-radius: 40px;
            font-size: 0.8rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            color: #2c4f6e;
            border: 1px solid #e0e8f0;
        }

        .filter-chip.active {
            background: #1f6392;
            color: white;
            border-color: #1f6392;
            box-shadow: 0 2px 6px rgba(31, 99, 146, 0.2);
        }

        .filter-chip:hover:not(.active) {
            background: #e6edf6;
            border-color: #bed0e2;
        }

        /* 工具卡片网格 */
        .tools-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 1.8rem;
            margin-top: 1rem;
        }

        /* 卡片样式 */
        .tool-card {
            background: #ffffff;
            border-radius: 1.75rem;
            transition: transform 0.2s ease, box-shadow 0.2s;
            box-shadow: 0 12px 24px -12px rgba(0, 0, 0, 0.08);
            border: 1px solid #eef2f8;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            backdrop-filter: blur(0px);
        }

        .tool-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 24px 36px -14px rgba(0, 0, 0, 0.18);
            border-color: #cddfee;
        }

        .card-inner {
            padding: 1.5rem 1.5rem 1.6rem;
            display: flex;
            flex-direction: column;
            flex: 1;
        }

        .tool-icon {
            font-size: 2.4rem;
            margin-bottom: 1rem;
        }

        .tool-title {
            font-size: 1.45rem;
            font-weight: 620;
            letter-spacing: -0.2px;
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            flex-wrap: wrap;
            margin-bottom: 0.6rem;
        }

        .tool-name {
            background: linear-gradient(120deg, #1f3b4c, #27648c);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
        }

        .tool-category {
            font-size: 0.7rem;
            background: #eef3fc;
            padding: 0.2rem 0.7rem;
            border-radius: 40px;
            color: #2a6d97;
            font-weight: 500;
        }

        .tool-desc {
            font-size: 0.88rem;
            color: #4d5f72;
            line-height: 1.45;
            margin: 0.6rem 0 1.2rem 0;
            flex: 1;
        }

        .tool-link {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: #eff3f8;
            padding: 0.6rem 1.2rem;
            border-radius: 40px;
            text-decoration: none;
            font-weight: 550;
            font-size: 0.85rem;
            color: #1f5c83;
            transition: all 0.2s;
            width: fit-content;
            border: 1px solid #e2eaf1;
        }

        .tool-link:hover {
            background: #1f6392;
            color: white;
            border-color: #1f6392;
            box-shadow: 0 4px 8px rgba(31, 99, 146, 0.2);
        }

        .tool-link span:first-child {
            font-size: 1rem;
        }

        /* 无结果样式 */
        .no-results {
            text-align: center;
            grid-column: 1 / -1;
            padding: 3rem;
            background: #ffffffcc;
            border-radius: 2rem;
            color: #5f7f9e;
        }

        /* 页脚 */
        .footer {
            margin-top: 4rem;
            text-align: center;
            font-size: 0.8rem;
            color: #5e7180;
            border-top: 1px solid #d6e2ef;
            padding-top: 2rem;
        }

        @media (max-width: 680px) {
            body {
                padding: 1rem;
            }
            h1 {
                font-size: 2rem;
            }
            .toolbar {
                flex-direction: column;
                align-items: stretch;
                border-radius: 1.5rem;
                padding: 1rem;
            }
            .filter-group {
                justify-content: center;
            }
        }
    </style>
</head>
<body>

<div class="container">
    <div class="hero">
        <div class="badge">🧰 每日搬砖利器 · 每个工具独立直达链接</div>
        <h1>⚡ 前端工具箱</h1>
        <div class="sub">精选静态工具 · 点击即用 · 提高开发效率</div>
    </div>

    <div class="toolbar">
        <div class="search-box">
            <span>🔍</span>
            <input type="text" id="searchInput" placeholder="搜索工具名称、描述...">
        </div>
        <div class="filter-group" id="filterGroup">
            <div class="filter-chip active" data-cat="all">全部</div>
            <div class="filter-chip" data-cat="代码工具">💻 代码工具</div>
            <div class="filter-chip" data-cat="颜色/设计">🎨 颜色/设计</div>
            <div class="filter-chip" data-cat="JSON/数据">📦 JSON/数据</div>
            <div class="filter-chip" data-cat="图标/字体">✨ 图标/字体</div>
            <div class="filter-chip" data-cat="性能/图片">🖼️ 性能/图片</div>
        </div>
    </div>

    <div class="tools-grid" id="toolsGrid">
        <!-- 动态渲染js工具列表，确保每个工具独立链接 -->
    </div>
    <div class="footer">
        🛠️ 每个工具卡片均包含独立外链 | 开源工具导航 · 收藏持续更新
    </div>
</div>

<script>
    // ---------- 工具数据集 ----------
    // 每个工具都有独立链接（url字段），支持新标签页打开
    const toolsData = [
        {
            id: 1,
            name: "JSON 格式化 & 校验器",
            category: "JSON/数据",
            icon: "📐",
            description: "在线JSON解析、压缩、转义、校验，支持树形视图与错误定位。",
            url: "https://jsonlint.com/",
            external: true
        },
        {
            id: 2,
            name: "JavaScript 正则测试",
            category: "代码工具",
            icon: "⚙️",
            description: "实时正则表达式测试工具，高亮匹配组，支持flag及替换预览。",
            url: "https://regex101.com/",
            external: true
        },
        {
            id: 3,
            name: "CSS 渐变生成器",
            category: "颜色/设计",
            icon: "🎨",
            description: "可视化生成linear-gradient/radial-gradient，输出CSS代码。",
            url: "https://cssgradient.io/",
            external: true
        },
        {
            id: 4,
            name: "Can I Use 兼容查询",
            category: "代码工具",
            icon: "🌐",
            description: "前端特性浏览器兼容性数据表，支持html、css、js api查询。",
            url: "https://caniuse.com/",
            external: true
        },
        {
            id: 5,
            name: "图标速查 · Iconify",
            category: "图标/字体",
            icon: "✨",
            description: "海量开源图标集 (Material, FontAwesome, Tabler等) 在线预览与复制代码。",
            url: "https://icon-sets.iconify.design/",
            external: true
        },
        {
            id: 6,
            name: "颜色调色板与转换",
            category: "颜色/设计",
            icon: "🎨",
            description: "HEX/RGB/HSL互转，智能取色器，WCAG对比度检查。",
            url: "https://coolors.co/",
            external: true
        },
        {
            id: 7,
            name: "HTML/CSS 代码压缩",
            category: "代码工具",
            icon: "🗜️",
            description: "Minify HTML/CSS/JS，移除空格注释，优化体积。",
            url: "https://www.minifier.org/",
            external: true
        },
        {
            id: 8,
            name: "图片压缩 · TinyPNG",
            category: "性能/图片",
            icon: "🖼️",
            description: "智能有损压缩WebP/PNG/JPEG，保持视觉质量。",
            url: "https://tinypng.com/",
            external: true
        },
        {
            id: 9,
            name: "Base64 编码/解码",
            category: "代码工具",
            icon: "🔐",
            description: "文本/图片Base64互转，支持UTF-8与DataURL生成。",
            url: "https://base64.guru/",
            external: true
        },
        {
            id: 10,
            name: "Flexbox 演练场",
            category: "代码工具",
            icon: "🧩",
            description: "可视化学习Flex布局，实时生成CSS代码。",
            url: "https://flexboxfroggy.com/",
            external: true
        },
        {
            id: 11,
            name: "Grid 布局生成器",
            category: "代码工具",
            icon: "🗂️",
            description: "交互式CSS Grid构造器，支持拖拽设定行列与间距。",
            url: "https://cssgrid-generator.netlify.app/",
            external: true
        },
        {
            id: 12,
            name: "阴影 & 模糊滤镜",
            category: "颜色/设计",
            icon: "💫",
            description: "box-shadow/text-shadow可视化，生成平滑多层阴影。",
            url: "https://neumorphism.io/",
            external: true
        },
        {
            id: 13,
            name: "Diff Checker 代码对比",
            category: "代码工具",
            icon: "🔍",
            description: "文本、JSON、代码差异对比，高亮不同行。",
            url: "https://www.diffchecker.com/",
            external: true
        },
        {
            id: 14,
            name: "图标字体 · Font Awesome",
            category: "图标/字体",
            icon: "🔤",
            description: "免费图标库，快速查找图标名称与CDN引用。",
            url: "https://fontawesome.com/icons",
            external: true
        },
        {
            id: 15,
            name: "网页调色板提取",
            category: "颜色/设计",
            icon: "🎨",
            description: "从图片或URL提取主题色板，生成CSS变量。",
            url: "https://imagecolorpicker.com/",
            external: true
        },
        {
            id: 16,
            name: "HTML 实体编码",
            category: "代码工具",
            icon: "🔣",
            description: "特殊字符转义/反转义，防止XSS注入。",
            url: "https://www.freeformatter.com/html-entities.html",
            external: true
        },
        {
            id: 17,
            name: "Crontab 语法生成",
            category: "代码工具",
            icon: "⏲️",
            description: "前端项目构建定时任务时，生成cron表达式。",
            url: "https://crontab.guru/",
            external: true
        },
        {
            id: 18,
            name: "数据模拟 Mock 工具",
            category: "JSON/数据",
            icon: "🎭",
            description: "在线生成Mock API JSON结构，快速原型。",
            url: "https://mockaroo.com/",
            external: true
        }
    ];

    // DOM 元素
    const toolsGrid = document.getElementById('toolsGrid');
    const searchInput = document.getElementById('searchInput');
    const filterChips = document.querySelectorAll('.filter-chip');
    
    let activeCategory = 'all';   // 'all' 或具体分类
    let searchKeyword = '';

    // 分类映射 (用于筛选)
    function filterTools() {
        let filtered = toolsData.filter(tool => {
            // 分类匹配
            if (activeCategory !== 'all' && tool.category !== activeCategory) return false;
            // 搜索匹配 (标题+描述)
            if (searchKeyword.trim() !== '') {
                const kw = searchKeyword.trim().toLowerCase();
                return tool.name.toLowerCase().includes(kw) || tool.description.toLowerCase().includes(kw);
            }
            return true;
        });
        renderTools(filtered);
    }

    // 渲染工具卡片 (每个工具单独链接)
    function renderTools(toolsArray) {
        if (!toolsGrid) return;
        if (toolsArray.length === 0) {
            toolsGrid.innerHTML = `<div class="no-results">🧩 没有找到相关工具，试试其他关键词吧～</div>`;
            return;
        }

        const cardsHtml = toolsArray.map(tool => {
            // 保证每个卡片拥有独立链接，外部链接添加 target="_blank" rel 安全属性
            const linkUrl = tool.url;
            // 如果url异常则用占位，但数据集都有真实链接
            return `
                <div class="tool-card" data-id="${tool.id}">
                    <div class="card-inner">
                        <div class="tool-icon">${tool.icon}</div>
                        <div class="tool-title">
                            <span class="tool-name">${escapeHtml(tool.name)}</span>
                            <span class="tool-category">${escapeHtml(tool.category)}</span>
                        </div>
                        <div class="tool-desc">${escapeHtml(tool.description)}</div>
                        <a href="${linkUrl}" class="tool-link" target="_blank" rel="noopener noreferrer">
                            <span>🔗</span> 访问工具 <span style="font-size:12px;">→</span>
                        </a>
                    </div>
                </div>
            `;
        }).join('');
        
        toolsGrid.innerHTML = cardsHtml;
    }

    // 简单防XSS
    function escapeHtml(str) {
        return str.replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        }).replace(/[\uD800-\uDBFF][\uDC00-\uDFFF]/g, function(c) {
            return c;
        });
    }

    // 分类激活切换样式
    function setActiveFilter(categoryValue) {
        filterChips.forEach(chip => {
            const chipCat = chip.getAttribute('data-cat');
            if (chipCat === categoryValue) {
                chip.classList.add('active');
            } else {
                chip.classList.remove('active');
            }
        });
    }

    // 事件绑定
    function bindEvents() {
        // 分类筛选
        filterChips.forEach(chip => {
            chip.addEventListener('click', () => {
                const cat = chip.getAttribute('data-cat');
                if (!cat) return;
                activeCategory = cat;
                setActiveFilter(activeCategory);
                filterTools();
            });
        });

        // 搜索防抖
        let debounceTimer;
        searchInput.addEventListener('input', (e) => {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(() => {
                searchKeyword = e.target.value;
                filterTools();
            }, 280);
        });
    }

    // 初始渲染 + 绑定事件
    function init() {
        bindEvents();
        // 默认显示全部工具
        activeCategory = 'all';
        setActiveFilter('all');
        searchKeyword = '';
        searchInput.value = '';
        renderTools(toolsData);
    }

    init();
</script>
</body>
</html>